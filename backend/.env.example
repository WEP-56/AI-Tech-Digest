# FastAPI/JWT settings
SECRET_KEY=replace-with-a-random-secret-at-least-32-chars

# Used to encrypt SMTP auth codes and LLM API keys in SQLite.
# Keep this stable after first deployment, or existing encrypted values cannot be decrypted.
ENCRYPTION_KEY=replace-with-a-random-encryption-secret

# Default admin account created on first startup.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-password

# Optional; defaults to backend/data/digest.db inside the container.
# DATABASE_URL=sqlite:////app/data/digest.db
